# Polymarket Agent example configuration.
# Copy this file to .env and fill in your own values. Do not commit .env.

# === Wallet ===
POLY_RPC_URL=https://polygon-rpc.com
POLY_PK=
POLY_ADDRESS=
POLY_PROXY_ADDRESS=
POLY_CHAIN_ID=137

# === CLOB API Credentials ===
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# === Optional data providers ===
DUNE_API_KEY=

# === Risk Limits ===
MAX_ORDER_SIZE=5
MAX_DAILY_LOSS=10
MAX_DAILY_TRADES=20
ALLOWED_MARKETS=
MAX_COST_PER_MARKET=25
MAX_LOSS_PER_MARKET=10

# === Price Limits ===
MAX_BUY_PRICE_YES=0.95
MIN_BUY_PRICE_NO=0.05
MIN_SPREAD_PCT=0.05

# === Mode Flags ===
DRY_RUN=true
LIVE_TRADING=false

# === Local runtime paths ===
DB_PATH=data/btc5m.db
BINANCE_SYMBOL=BTCUSDT
COLLECTOR_INTERVAL_SEC=2
MAX_MARKETS=10
